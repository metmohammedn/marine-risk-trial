# Marine Weather Risk — Demo. Environment Configuration
# Copy to .env and adjust as needed

# Open-Meteo API key (commercial subscription — leave blank for free tier)
# When set, automatically switches to customer-*.open-meteo.com endpoints
OPENMETEO_API_KEY=

# Redis cache (optional — app works without it)
# Use 127.0.0.1 (not localhost) — localhost triggers IPv6 resolution loops on macOS
# that stall startup ~30s before the socket timeout trips when Redis isn't running.
REDIS_URL=redis://127.0.0.1:6379/0

# API tuning
API_TIMEOUT=30
API_MAX_CONNECTIONS=10

# App
DEBUG=true
HOST=0.0.0.0
PORT=8050

# Data source: "open-meteo" (default) or "bom" (future)
DATA_SOURCE=open-meteo

# PostHog analytics — leave blank to disable.
# US Cloud project API key starts with "phc_". Write-only public key; safe to
# ship in the frontend (PostHog designed it this way).
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Build identifier — attached to every PostHog event as super-property.
# In prod, set to the short git SHA via a build arg; locally leave as "dev".
APP_VERSION=dev
